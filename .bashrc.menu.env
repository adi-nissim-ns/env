#!/bin/bash
#https://wiki.nextsilicon.com/wiki/software/software-bringup/utils-toolchain-install


# git fetch
# git checkout origin/master
# ./setup.sh --fetch-all
# ./setup.sh --create-buildtools-venv
# ./build.sh --clean --install [--debug | --release]

function stage1_clone_nextutils() {
  echo_running "clone nextutils..."
  cdsw
  run_command pwd
  # Check if directory exists
  if [ ! -d "$NEXTUTILS" ]; then
    echo_info "Directory $NEXTUTILS does not exist. cloning it..."
    cdsw
    run_command git clone --recurse-submodules git@github.com:nextsilicon/nextutils.git
  else    
    echo_warning "Directory $NEXTUTILS exists. Do nothing."
  fi
}

function stage2_setup_nextutils() {
  echo_running "Setting up nextutils..."
  cdutils
  run_command pwd
  # Check if directory exists
  if [ ! -d "$NEXTUTILS" ]; then
    echo_error "Directory $HOME/nextutils does not exist."
    echo_info "You can run 'stage1_clone_nextutils' to clone it."
  else
    echo_running "Directory $NEXTUTILS exists. Proceeding with setup..."
    run_command cd $NEXTUTILS
    # echo "Running: ./setup.sh --fetch-all --create-buildtools-venv"
    run_command ./setup.sh --fetch-all --create-buildtools-venv && echo "[OK] nextutils setup complete."
  fi
}
function stage3_build_nextutils() {
  if [ ! -d "$NEXTUTILS" ]; then
    echo_error "NEXTUTILS directory does not exist: $NEXTUTILS"
    echo_info "step1: run 'stage1_clone_nextutils'"
    echo_info "step2: run 'stage2_setup_nextutils'"
    return 1
  fi
  echo_running "Building nextutils in $NEXTUTILS ..."
  (cd "$NEXTUTILS" && run_command ./build.sh --install --no-tests) && echo_success "nextutils build complete."
}
function build_nextutils_with_tests() {
  if [ ! -d "$NEXTUTILS" ]; then
    echo_error "NEXTUTILS directory does not exist: $NEXTUTILS"
    echo_info "step1: run 'stage1_clone_nextutils'"
    echo_info "step2: run 'stage2_setup_nextutils'"
    return 1
  fi
  echo_running "Building nextutils in $NEXTUTILS ..."
  (cd "$NEXTUTILS" && run_command ./build.sh --install) && echo_success "nextutils build complete."
}
function build_nextutils_with_tests_clean() {
  if [ ! -d "$NEXTUTILS" ]; then
    echo_error "NEXTUTILS directory does not exist: $NEXTUTILS"
    echo_info "step1: run 'stage1_clone_nextutils'"
    echo_info "step2: run 'stage2_setup_nextutils'"
    return 1
  fi
  echo_running "Building nextutils in $NEXTUTILS ..."
  (cd "$NEXTUTILS" && run_command ./build.sh --install --clean) && echo_success "nextutils build complete."
}
function _env_detect_default_branch() {
  local _url="$1"
  timeout 8 git ls-remote --symref "$_url" HEAD 2>/dev/null \
      | awk '/^ref:/ {sub("refs/heads/",""); print $2; exit}'
}

# Describe a single clone/worktree directory — one formatted line.
# Usage: _env_wt_info_line <dir>
function _env_wt_info_line() {
  local _d="$1"
  local _branch; _branch=$(git -C "$_d" branch --show-current 2>/dev/null || echo "?")
  local _kind _parent=""
  if [[ -d "${_d}/.git" ]]; then
    _kind="standalone"
  else
    _kind="worktree"
    # Try remote tracking first, then branch reflog "Created from <base>"
    _parent=$(git -C "$_d" rev-parse --abbrev-ref @{u} 2>/dev/null)
    if [[ -z "$_parent" ]]; then
      _parent=$(git -C "$_d" reflog show "${_branch}" --pretty='%gs' 2>/dev/null \
                | awk '/branch: Created from/{print $NF; exit}')
    fi
    _parent="${_parent:-?}"
  fi
  if [[ "$_kind" == "standalone" ]]; then
    printf "  %-22s  standalone clone    branch: %s\n" "$(basename "$_d")" "$_branch"
  else
    printf "  %-22s  worktree            branch: %-20s  from: %s\n" "$(basename "$_d")" "$_branch" "$_parent"
  fi
}

# List all clone dirs in a group, print numbered rows, populate array.
# Usage: _env_list_wt_group <wt_root_dir> <out_array_name>
function _env_list_wt_group() {
  local _root="$1"
  local -n _out_arr="$2"
  _out_arr=()
  local _d
  for _d in "${_root}"/*/; do
    [[ -d "$_d" ]] || continue
    _out_arr+=("${_d%/}")
  done
  local _i
  for _i in "${!_out_arr[@]}"; do
    printf "    %s." "$((_i+1))"
    _env_wt_info_line "${_out_arr[$_i]}"
  done
}

# Show all known clones across all bases for all repos in repos.conf
function _env_show_all_clones() {
  local _repos_conf="${_ENV_PROJECT_DIR}/repos.conf"
  local -a _bases=() _blabels=()
  local _b _bl
  while IFS= read -r _b; do
      _bl=$(_nextenv_space_name "$_b")
      _bases+=("$_b"); _blabels+=("$_bl")
  done < <(_nextenv_known_bases)

  # Optionally filter to one base
  local _filter_base=""
  if [[ ${#_bases[@]} -gt 1 ]]; then
      echo ""
      echo "  Show clones for:"
      local _bi
      for _bi in "${!_bases[@]}"; do
          printf "    %s. %s  (%s)\n" "$((_bi+1))" "${_blabels[$_bi]}" "${_bases[$_bi]}"
      done
      printf "    a. All spaces\n"
      echo ""
      read -rp "  Select (0 to cancel): " _bsel
      [[ "$_bsel" == "0" || -z "$_bsel" ]] && return
      if [[ "$_bsel" != "a" && "$_bsel" != "A" ]]; then
          if [[ "$_bsel" =~ ^[0-9]+$ ]] && [[ "$_bsel" -ge 1 ]] && [[ "$_bsel" -le ${#_bases[@]} ]]; then
              _filter_base="${_bases[$((_bsel-1))]}"
          else
              echo_error "Invalid selection"; return
          fi
      fi
  fi

  local -a _rnames=() _rurls=() _rsubdirs=()
  if [[ -f "$_repos_conf" ]]; then
      while IFS='|' read -r _rn _ru _rs _rd; do
          [[ "$_rn" =~ ^#.*$ || -z "$_rn" ]] && continue
          _rnames+=("$_rn"); _rurls+=("$_ru"); _rsubdirs+=("$_rs")
      done < "$_repos_conf"
  fi

  local _found=0
  for _bi in "${!_bases[@]}"; do
      local _base="${_bases[$_bi]}"
      [[ -n "$_filter_base" && "$_base" != "$_filter_base" ]] && continue
      local _label="${_blabels[$_bi]}"
      local _header_printed=0

      # Scan worktree groups: <base>/sw/<repo>_wt/
      local _wt_root_parent="${_base}/sw"
      if [[ -d "$_wt_root_parent" ]]; then
          local _wtg
          for _wtg in "${_wt_root_parent}"/*_wt/; do
              [[ -d "$_wtg" ]] || continue
              if [[ $_header_printed -eq 0 ]]; then
                  echo ""
                  printf "══ %s  (%s) ══\n" "$_label" "$_base"
                  _header_printed=1; _found=1
              fi
              local _rname; _rname=$(basename "${_wtg%_wt/}")
              printf "  [%s]  %s\n" "$_rname" "${_wtg}"
              local _d
              for _d in "${_wtg}"*/; do
                  [[ -d "$_d" ]] || continue
                  _env_wt_info_line "${_d%/}"
              done
          done
      fi

      # Scan normal clones from repos.conf subdir list
      local _ri
      for _ri in "${!_rnames[@]}"; do
          local _norm_dest="${_base}/sw/${_rsubdirs[$_ri]}"
          [[ -d "$_norm_dest/.git" ]] || continue
          # Skip if it looks like a wt group entry (already shown above)
          [[ "$_norm_dest" == *_wt/* ]] && continue
          if [[ $_header_printed -eq 0 ]]; then
              echo ""
              printf "══ %s  (%s) ══\n" "$_label" "$_base"
              _header_printed=1; _found=1
          fi
          local _branch; _branch=$(git -C "$_norm_dest" branch --show-current 2>/dev/null || echo "?")
          printf "  [%s]  %s\n" "${_rnames[$_ri]}" "$_norm_dest"
          printf "  %-22s  normal clone        branch: %s\n" "${_rnames[$_ri]}" "$_branch"
      done
  done
  [[ $_found -eq 0 ]] && echo_info "No clones found."
}

function menu-env() {
  echo ""
  echo "====================env_menu===================="
  echo "0. Exit"
  echo "1. back to main menu"
  echo "2. step1: clone nextutils"
  echo "2.1. INSTALL: Pre-Commit"
  echo "2.2. INSTALL: Vs-code settings"
  echo "3. step2: setup nextutils (./setup.sh --fetch-all --create-buildtools-venv)"
  echo "4. step3: build & install nextutils (./build.sh --install --no-tests )"
  echo "4.1 step3: build & install nextutils (./build.sh --install )"
  echo "4.2 step3: build & install nextutils (./build.sh --install --clean )"
#  echo "5. step4: download most updated config : ${NEXT_HOME}/etc/next_runtime.conf"
  echo ""
  echo " --- other options:"
  echo "6. clean build dir"
  echo "7. clean ~/.cache ~/.conan2"
  echo "8. git submodule update --init --recursive"
  echo "9. run ./setup.sh --default --force"
  echo "10. cmake only: ./build.sh --config-only"
  echo "11. build with ninja"
  echo "12. clone a repo from known list"
  echo "13. show all clones across spaces"
  echo "=====================env_menu===================="
  
  read -p "Select an option: " option
  case $option in
    0)
      echo "Exiting..."
      return 0
      ;;
    1)
      menu
      ;;
    2)
      stage1_clone_nextutils
      ;;
    2.1)
      run_command cdutils
      run_command pwd
      # run_command ./setup.sh --install-pre-commit
      run_command pip install -U pre-commit identify && pre-commit install
      ;;
    2.2)
      run_command cdutils
      run_command pwd
      run_command ./setup.sh --install-vscode-settings
      ;;
    3)
      stage2_setup_nextutils
      ;;
    4)
      stage3_build_nextutils
      ;;
    4.1)
      build_nextutils_with_tests
      ;;
    4.2)
      build_nextutils_with_tests_clean
      ;;
      #run_command cdutils
      #run_command pwd
      #run_command ./setup.sh --install-cfg-files --randomize-ports
    6)
      run_command rm -rf "${NEXTUTILS}/build"
      ;;
    7)
      echo_info "Cleaning per-worktree cache dirs in $NEXTUTILS"
      run_command rm -rf "${NEXTUTILS}/.conan2/"*
      run_command rm -rf "${NEXTUTILS}/.cache/"*
      run_command rm -rf "${NEXTUTILS}/.ccache/"*
      run_command rm -rf "${NEXTUTILS}/.uv_cache/"*
      ;;
    8)
      (cd "$NEXTUTILS" && run_command git submodule update --init --recursive)
      ;;
    9)
      (cd "$NEXTUTILS" && run_command ./setup.sh --default --force)
      ;;
    10)
      (cd "$NEXTUTILS" && run_command ./build.sh --config-only)
      ;;
    11)
      (cd "$NEXTUTILS/build" && run_command ninja)
      ;;
    12)
      local _repos_conf="${_ENV_PROJECT_DIR}/repos.conf"
      if [[ ! -f "$_repos_conf" ]]; then
          echo_error "repos.conf not found at ${_repos_conf}"
          menu-env; return
      fi
      local -a _rnames=() _rurls=() _rsubdirs=() _rdescs=()
      while IFS='|' read -r _rn _ru _rs _rd; do
          [[ "$_rn" =~ ^#.*$ || -z "$_rn" ]] && continue
          _rnames+=("$_rn"); _rurls+=("$_ru"); _rsubdirs+=("$_rs"); _rdescs+=("$_rd")
      done < "$_repos_conf"
      echo ""
      printf "  %-4s  %-20s  %-40s  %s\n" "#" "Name" "URL" "Description"
      printf "  %-4s  %-20s  %-40s  %s\n" "----" "--------------------" "----------------------------------------" "-----------"
      local _ri
      for _ri in "${!_rnames[@]}"; do
          printf "  %-4s  %-20s  %-40s  %s\n" "$((_ri+1))" "${_rnames[$_ri]}" "${_rurls[$_ri]}" "${_rdescs[$_ri]}"
      done
      echo ""
      read -rp "Select repo to clone (0 to cancel): " _rsel
      [[ "$_rsel" == "0" || -z "$_rsel" ]] && { menu-env; return; }
      if ! [[ "$_rsel" =~ ^[0-9]+$ ]] || [[ "$_rsel" -lt 1 ]] || [[ "$_rsel" -gt ${#_rnames[@]} ]]; then
          echo_error "Invalid selection"
          menu-env; return
      fi
      local _idx=$((_rsel-1))
      local _rname="${_rnames[$_idx]}"
      local _rurl="${_rurls[$_idx]}"
      local _rsubdir="${_rsubdirs[$_idx]}"
      # ── Clone type ──────────────────────────────────────────────────────
      echo ""
      echo "  Clone type for ${_rname}:"
      printf "    1. Normal clone      →  %s\n" "${SW_HOME}/${_rsubdir}"
      echo "    2. Standalone clone  — independent copy per-branch (like nextutils worktrees)"
      echo ""
      read -rp "Select clone type (0 to cancel): " _ctype
      [[ "$_ctype" == "0" || -z "$_ctype" ]] && { menu-env; return; }
      case "$_ctype" in
        1)
          # ── Base selection for normal clone ────────────────────────────
          local -a _bases=() _blabels=()
          local _b _bl
          while IFS= read -r _b; do
              _bl=$(_nextenv_space_name "$_b")
              _bases+=("$_b"); _blabels+=("$_bl")
          done < <(_nextenv_known_bases)
          echo ""
          echo "  Select server to clone to:"
          local _bi
          for _bi in "${!_bases[@]}"; do
              printf "    %s. %-12s  %s/sw/%s\n" "$((_bi+1))" "${_blabels[$_bi]}" "${_bases[$_bi]}" "${_rsubdir}"
          done
          echo ""
          read -rp "Select server (0 to cancel): " _bsel
          [[ "$_bsel" == "0" || -z "$_bsel" ]] && { menu-env; return; }
          if ! [[ "$_bsel" =~ ^[0-9]+$ ]] || [[ "$_bsel" -lt 1 ]] || [[ "$_bsel" -gt ${#_bases[@]} ]]; then
              echo_error "Invalid selection"
              menu-env; return
          fi
          local _dest="${_bases[$((_bsel-1))]}/sw/${_rsubdir}"
          if [[ -d "$_dest" ]]; then
              echo_warning "Destination already exists: ${_dest}"
          else
              echo_info "Cloning ${_rname} into ${_dest}"
              run_command mkdir -p "$(dirname "$_dest")"
              run_command git clone --recurse-submodules "${_rurl}" "$_dest"
          fi
          ;;
        2)
          # ── Discover existing groups across all known bases ────────────
          local -a _eg_bases=() _eg_labels=()
          local _b _bl
          while IFS= read -r _b; do
              _bl=$(_nextenv_space_name "$_b")
              local _wt_root="${_b}/sw/${_rname}_wt"
              if [[ -d "$_wt_root" ]]; then
                  local _existing
                  _existing=$(ls "$_wt_root" 2>/dev/null | tr '\n' ' ')
                  _eg_bases+=("$_b"); _eg_labels+=("[${_bl}]  ${_existing}")
              fi
          done < <(_nextenv_known_bases)
          # ── Step 1: action selection ───────────────────────────────────
          local _do_worktree_add=0
          local _do_switch=0
          local _do_delete=0
          local _wt_base=""
          if [[ ${#_eg_bases[@]} -gt 0 ]]; then
              echo ""
              echo "  What do you want to do?"
              echo "    w. Add a worktree   (git worktree add — fast, shared objects)"
              echo "    s. Switch branch of an existing worktree"
              echo "    d. Delete a worktree"
              echo "    n. Start a fresh clone on a new server"
              echo ""
              read -rp "  Select (w/s/d/n, 0 to cancel): " _wt_action
              [[ "$_wt_action" == "0" || -z "$_wt_action" ]] && { menu-env; return; }
              if [[ "$_wt_action" == "s" || "$_wt_action" == "S" ]]; then
                  _do_switch=1
              elif [[ "$_wt_action" == "w" || "$_wt_action" == "W" ]]; then
                  _do_worktree_add=1
              elif [[ "$_wt_action" == "d" || "$_wt_action" == "D" ]]; then
                  _do_delete=1
              fi
              if [[ $_do_worktree_add -eq 1 || $_do_switch -eq 1 || $_do_delete -eq 1 ]]; then
                  if [[ ${#_eg_bases[@]} -eq 1 ]]; then
                      _wt_base="${_eg_bases[0]}"
                  else
                      echo ""
                      echo "  Select group:"
                      local _ei
                      for _ei in "${!_eg_bases[@]}"; do
                          printf "    %s. %s\n" "$((_ei+1))" "${_eg_labels[$_ei]}"
                      done
                      echo ""
                      read -rp "  Select (0 to cancel): " _esel
                      [[ "$_esel" == "0" || -z "$_esel" ]] && { menu-env; return; }
                      if ! [[ "$_esel" =~ ^[0-9]+$ ]] || [[ "$_esel" -lt 1 ]] || [[ "$_esel" -gt ${#_eg_bases[@]} ]]; then
                          echo_error "Invalid selection"; menu-env; return
                      fi
                      _wt_base="${_eg_bases[$((_esel-1))]}"
                  fi
              fi
          fi
          # ── Step 2s: switch branch ─────────────────────────────────────
          if [[ $_do_switch -eq 1 ]]; then
              local _wt_root="${_wt_base}/sw/${_rname}_wt"
              local -a _wt_dirs=()
              echo ""
              echo "  Select worktree to switch:"
              _env_list_wt_group "$_wt_root" _wt_dirs
              echo ""
              read -rp "  Select (0 to cancel): " _wsel
              [[ "$_wsel" == "0" || -z "$_wsel" ]] && { menu-env; return; }
              if ! [[ "$_wsel" =~ ^[0-9]+$ ]] || [[ "$_wsel" -lt 1 ]] || [[ "$_wsel" -gt ${#_wt_dirs[@]} ]]; then
                  echo_error "Invalid selection"; menu-env; return
              fi
              local _wt_path="${_wt_dirs[$((_wsel-1))]}"
              read -rp "  New branch (empty to cancel): " _new_branch
              [[ -z "$_new_branch" ]] && { menu-env; return; }
              run_command git -C "$_wt_path" fetch origin
              if git -C "$_wt_path" ls-remote --exit-code --heads origin "${_new_branch}" &>/dev/null; then
                  run_command git -C "$_wt_path" checkout "${_new_branch}"
              else
                  local _base_branch
                  read -rp "  Branch '${_new_branch}' not on remote — base branch (empty to cancel): " _base_branch
                  [[ -z "$_base_branch" ]] && { menu-env; return; }
                  run_command git -C "$_wt_path" checkout -b "${_new_branch}" "${_base_branch}"
              fi
          # ── Step 2d: delete worktree ───────────────────────────────────
          elif [[ $_do_delete -eq 1 ]]; then
              local _wt_root="${_wt_base}/sw/${_rname}_wt"
              local -a _wt_dirs=()
              echo ""
              echo "  Select worktree to delete:"
              _env_list_wt_group "$_wt_root" _wt_dirs
              echo ""
              read -rp "  Select (0 to cancel): " _dsel
              [[ "$_dsel" == "0" || -z "$_dsel" ]] && { menu-env; return; }
              if ! [[ "$_dsel" =~ ^[0-9]+$ ]] || [[ "$_dsel" -lt 1 ]] || [[ "$_dsel" -gt ${#_wt_dirs[@]} ]]; then
                  echo_error "Invalid selection"; menu-env; return
              fi
              local _del_path="${_wt_dirs[$((_dsel-1))]}"
              echo ""
              echo_info "$(_env_wt_info_line "$_del_path")"
              read -rp "  Delete '$(basename "$_del_path")'? [y/N]: " _confirm
              [[ "$_confirm" != "y" && "$_confirm" != "Y" ]] && { echo "Cancelled."; menu-env; return; }
              if [[ -f "${_del_path}/.git" ]]; then
                  # Linked worktree — find parent and use git worktree remove
                  local _parent_clone=""
                  local _d
                  for _d in "${_wt_root}"/*/; do
                      [[ -d "${_d}/.git" ]] && { _parent_clone="${_d%/}"; break; }
                  done
                  if [[ -n "$_parent_clone" ]]; then
                      run_command git -C "$_parent_clone" worktree remove --force "$_del_path"
                      run_command git -C "$_parent_clone" worktree prune
                  else
                      run_command rm -rf "$_del_path"
                  fi
              else
                  # Standalone/base clone — plain rm
                  echo_warning "This is a base clone — deleting with rm -rf"
                  run_command rm -rf "$_del_path"
              fi
          # ── Step 2a: worktree add ──────────────────────────────────────
          elif [[ $_do_worktree_add -eq 1 ]]; then
              local _wt_root="${_wt_base}/sw/${_rname}_wt"
              # Find the main clone (has .git as a directory, not a file)
              local _parent_clone=""
              local _d
              for _d in "${_wt_root}"/*/; do
                  [[ -d "${_d}/.git" ]] && { _parent_clone="${_d%/}"; break; }
              done
              if [[ -z "$_parent_clone" ]]; then
                  echo_error "No main clone found in ${_wt_root} — all entries are already worktrees?"
                  menu-env; return
              fi
              read -rp "  Branch to check out (empty to cancel): " _branch
              [[ -z "$_branch" ]] && { menu-env; return; }
              local _wt_dest="${_wt_root}/${_branch}"
              if [[ -d "$_wt_dest" ]]; then
                  echo_error "Already exists: ${_wt_dest}"; menu-env; return
              fi
              # Check if branch exists on remote
              run_command git -C "$_parent_clone" fetch origin
              if git -C "$_parent_clone" ls-remote --exit-code --heads origin "${_branch}" &>/dev/null; then
                  echo_info "Adding worktree ${_branch} (remote branch) in ${_wt_root}"
                  run_command git -C "$_parent_clone" worktree add "../${_branch}" "${_branch}"
              else
                  echo_info "Branch '${_branch}' not on remote — creating new branch"
                  local _base_branch
                  read -rp "  Base branch to branch from (empty to cancel): " _base_branch
                  [[ -z "$_base_branch" ]] && { menu-env; return; }
                  run_command git -C "$_parent_clone" worktree add -b "${_branch}" "../${_branch}" "${_base_branch}"
              fi
              run_command git -C "$_wt_dest" submodule update --init --recursive
          else
          # ── Step 2b: fresh clone — pick base ──────────────────────────
          local -a _bases=() _blabels=()
          while IFS= read -r _b; do
              _bl=$(_nextenv_space_name "$_b")
              _bases+=("$_b"); _blabels+=("$_bl")
          done < <(_nextenv_known_bases)
          echo ""
          echo "  Select server for new clone:"
          local _bi
          for _bi in "${!_bases[@]}"; do
              printf "    %s. %-12s  %s/sw/%s_wt/\n" "$((_bi+1))" "${_blabels[$_bi]}" "${_bases[$_bi]}" "${_rname}"
          done
          echo ""
          read -rp "Select server (0 to cancel): " _bsel
          [[ "$_bsel" == "0" || -z "$_bsel" ]] && { menu-env; return; }
          if ! [[ "$_bsel" =~ ^[0-9]+$ ]] || [[ "$_bsel" -lt 1 ]] || [[ "$_bsel" -gt ${#_bases[@]} ]]; then
              echo_error "Invalid selection"; menu-env; return
          fi
          local _base_dir="${_bases[$((_bsel-1))]}"
          local _wt_root="${_base_dir}/sw/${_rname}_wt"
          # ── Auto-detect default branch ─────────────────────────────────
              echo_info "Detecting default branch for ${_rname}..."
              local _branch
              _branch=$(_env_detect_default_branch "$_rurl")
              if [[ -z "$_branch" ]]; then
                  read -rp "  Could not reach remote — enter branch name (empty to cancel): " _branch
                  [[ -z "$_branch" ]] && { menu-env; return; }
              else
                  echo_info "Default branch: ${_branch}"
              fi
          # ── Fresh clone ────────────────────────────────────────────────
          local _wt_dest="${_wt_root}/${_branch}"
          if [[ -d "$_wt_dest" ]]; then
              echo_error "Already exists: ${_wt_dest}"; menu-env; return
          fi
          echo_info "Cloning ${_rname}:${_branch} into ${_wt_dest}"
          run_command mkdir -p "$(dirname "$_wt_dest")"
          run_command git clone -b "${_branch}" --recurse-submodules "${_rurl}" "$_wt_dest"
          fi  # end switch / worktree-add / fresh-clone
          ;;
        *)
          echo_error "Invalid option"
          ;;
      esac
      ;;
    13)
      _env_show_all_clones
      ;;
    *)
      echo "Invalid option. Please try again."
      menu
      ;;
  esac
}

echo_info "loading menu-env ..."

